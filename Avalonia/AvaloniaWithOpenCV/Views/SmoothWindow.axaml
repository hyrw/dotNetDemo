<Window
    x:Class="AvaloniaWithOpenCV.SmoothWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="SmoothWindow"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Window.Resources>
        <DrawingBrush
            x:Key="gridBrush"
            DestinationRect="0 0 50 50"
            SourceRect="0 0 50 50"
            TileMode="Tile">
            <DrawingBrush.Drawing>
                <DrawingGroup>
                    <DrawingGroup.Children>
                        <!--<GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <GeometryGroup>
                                    <LineGeometry StartPoint="10 0" EndPoint="10 50" />
                                    <LineGeometry StartPoint="20 0" EndPoint="20 50" />
                                    <LineGeometry StartPoint="30 0" EndPoint="30 50" />
                                    <LineGeometry StartPoint="40 0" EndPoint="40 50" />

                                    <LineGeometry StartPoint="0 10" EndPoint="50 10" />
                                    <LineGeometry StartPoint="0 20" EndPoint="50 20" />
                                    <LineGeometry StartPoint="0 30" EndPoint="50 30" />
                                    <LineGeometry StartPoint="0 40" EndPoint="50 40" />
                                </GeometryGroup>
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Brush="LightGray" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>-->
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <PathGeometry Figures="M0,10 H50 M0,20 H50 M0,30 H50 M0,40 H50 M10,0 V50 M20,0 V50 M30,0 V50 M40,0 V50" />
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Brush="LightGray" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Geometry>
                                <PathGeometry Figures="M0,50 L0,0 50,0" />
                            </GeometryDrawing.Geometry>
                            <GeometryDrawing.Pen>
                                <Pen Brush="DarkGray" />
                            </GeometryDrawing.Pen>
                        </GeometryDrawing>
                    </DrawingGroup.Children>
                </DrawingGroup>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>
    <Grid
        Margin="20"
        Background="Transparent"
        DragDrop.AllowDrop="True"
        DragDrop.Drop="Drop">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="auto" />
            <ColumnDefinition />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="10,0,20,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="缩放" />
                <NumericUpDown
                    Width="150"
                    Increment="0.1"
                    Maximum="1"
                    Minimum="0.1"
                    ValueChanged="ResizeChanged"
                    Value="1" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="中值滤波" />
                <NumericUpDown
                    Width="150"
                    Increment="2"
                    Minimum="1"
                    ValueChanged="MedianBlurChanged"
                    Value="1" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="距离" />
                <NumericUpDown
                    Width="150"
                    Increment="1"
                    Minimum="0"
                    ValueChanged="DistanceChanged"
                    Value="1" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="插入点数" />
                <NumericUpDown
                    Width="150"
                    Minimum="1"
                    ValueChanged="NumChanged"
                    Value="1" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="强度" />
                <NumericUpDown
                    Width="150"
                    Minimum="1"
                    ValueChanged="StrengthChanged"
                    Value="1" />
            </StackPanel>
            <StackPanel Orientation="Horizontal">
                <TextBlock VerticalAlignment="Center" Text="最小删除点数" />
                <NumericUpDown
                    Width="150"
                    Minimum="0"
                    ValueChanged="MinimumDeletionNumChanged"
                    Value="0" />
            </StackPanel>
        </StackPanel>
        <Grid Grid.Column="1" Background="{StaticResource gridBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition />
                <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Image
                Name="BeforeImage"
                Grid.Column="0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />
            <Image
                Name="AfterImage"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Stretch="Uniform" />
        </Grid>
    </Grid>
</Window>
