<Window
x:Class="AvaloniaWithOpenCV.Views.MainWindow"
xmlns="https://github.com/avaloniaui"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:vm="using:AvaloniaWithOpenCV.ViewModels"
Title="AvaloniaWithOpenCV"
Width="800"
Height="900"
d:DesignHeight="800"
d:DesignWidth="900"
x:DataType="vm:MainWindowViewModel"
Icon="/Assets/avalonia-logo.ico"
DragDrop.AllowDrop="True"
DragDrop.Drop="Drop"
mc:Ignorable="d">

	<!--<Design.DataContext>
	<vm:MainWindowViewModel />
	</Design.DataContext>-->

	<DockPanel>
		<Menu DockPanel.Dock="Top">
			<MenuItem Header="二值化">
				<MenuItem Header="二值化" Command="{Binding OpenThresholdWindowCommand}"/>
			</MenuItem>
			<MenuItem Header="颜色分割">
				<MenuItem Header="HSV" Command="{Binding OpenColorRangeWindowCommand}"/>
				<Separator/>
				<MenuItem Header="RGB" Command="{Binding OpenColorRangeWindowCommand}"/>
			</MenuItem>
		</Menu>
		<Grid Margin="20" Background="Transparent">
			<Image Name="TheImage" VerticalAlignment="Center"
				   RenderOptions.BitmapInterpolationMode="HighQuality"
				   HorizontalAlignment="Center"
				   Stretch="Uniform" />
		</Grid>
	</DockPanel>
</Window>
