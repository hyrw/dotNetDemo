<UserControl
    x:Class="OpenCvToolkit.Views.MainView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="clr-namespace:OpenCvToolkit.ViewModels"
    xmlns:controls="clr-namespace:OpenCvToolkit.Controls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vm:MainViewModel"
    DragDrop.AllowDrop="True"
    mc:Ignorable="d">
    <Interaction.Behaviors>
        <EventTriggerBehavior EventName="Loaded">
            <InvokeCommandAction Command="{Binding LoadImageCommand}" />
        </EventTriggerBehavior>
        <RoutedEventTriggerBehavior RoutedEvent="{x:Static DragDrop.DropEvent}">
            <InvokeCommandAction Command="{Binding DropImageCommand}" PassEventArgsToCommand="True"/>
        </RoutedEventTriggerBehavior>
    </Interaction.Behaviors>
    <Design.DataContext>
        <!--
            This only sets the DataContext for the previewer in an IDE,
            to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs)
        -->
        <vm:MainViewModel />
    </Design.DataContext>

    <Grid Background="Transparent">
        <UniformGrid Columns="2" >
        <controls:ZoomViewer x:Name="beforeViewer"
                            Matrix="{Binding SyncMatrix, Mode=TwoWay}"
                            EnableZoom="True"
                            Scale="1.0"
                            Background="Transparent">
            <Image Source="{Binding Before}"/>
        </controls:ZoomViewer>
        <controls:ZoomViewer x:Name="afterViewer"
                            Matrix="{Binding SyncMatrix, Mode=TwoWay}"
                            EnableZoom="True"
                            Scale="1.0"
                            Background="Transparent">
            <Image Source="{Binding After}"/>
        </controls:ZoomViewer>
        </UniformGrid>
        
        <!-- 拖拽提示 -->
        <Border x:Name="DragHintBorder"
                Background="#80000000" 
                CornerRadius="8"
                Padding="20"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                IsVisible="{Binding Before, Converter={x:Static ObjectConverters.IsNull}}">
            <StackPanel Spacing="8" HorizontalAlignment="Center">
                <TextBlock Text="📁 拖拽图片文件到此区域"
                           FontSize="16"
                           Foreground="White"
                           HorizontalAlignment="Center"/>
                <TextBlock Text="支持格式: JPG, PNG, BMP, GIF, TIFF, WEBP"
                           FontSize="12"
                           Foreground="#CCCCCC"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
