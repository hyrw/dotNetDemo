<Window x:Class="OverlayDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OverlayDemo"
        mc:Ignorable="d"
        Topmost="True"
        LostFocus="Window_LostFocus"
        Height="100"
        Width="300"
        Title="MainWindow" >
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center"  TextElement.Foreground="DarkOrange">
        <TextBlock x:Name="textBlock" FontSize="32" FontWeight="Bold"/>
    </Grid>
</Window>
