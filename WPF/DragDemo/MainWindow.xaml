<Window
    x:Class="DragDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:DragDemo.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:DragDemo"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:DragDemo.Views"
    xmlns:vms="clr-namespace:DragDemo.ViewModels"
    Title="MainWindow"
    Width="800"
    Height="450"
    d:DataContext="{d:DesignInstance Type=vms:MainWindowViewModel}"
    mc:Ignorable="d">
    <Window.DataContext>
        <vms:MainWindowViewModel />
    </Window.DataContext>
    <Grid>
        <views:TodoView>
            <views:TodoView.DataContext>
                <vms:TodoViewModel />
            </views:TodoView.DataContext>
        </views:TodoView>
    </Grid>
</Window>
