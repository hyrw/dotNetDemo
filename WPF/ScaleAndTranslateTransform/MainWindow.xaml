<Window
    x:Class="ScaleAndTranslateTransform.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:ScaleAndTranslateTransform"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="MainWindow"
    Width="1920"
    Height="1080"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  工具栏  -->
        <StackPanel
            Grid.Row="0"
            Margin="10"
            Orientation="Horizontal">
            <Button
                Margin="5"
                Padding="10,5"
                Click="ResetButton_Click"
                Content="重置变换" />
        </StackPanel>

        <Grid
            Grid.Row="1"
            Grid.Column="2"
            Background="LightGray"
            ClipToBounds="True"
            ColumnDefinitions="auto,*"
            MouseLeftButtonDown="Grid_MouseLeftButtonDown"
            MouseLeftButtonUp="Grid_MouseLeftButtonUp"
            MouseMove="Grid_MouseMove"
            MouseWheel="Grid_MouseWheel">
            <Grid
                x:Name="EleContainer"
                Grid.Column="1"
                ClipToBounds="True"
                RenderTransformOrigin="0,0">
                <Grid.RenderTransform>
                    <TransformGroup x:Name="transformGroup">
                        <ScaleTransform x:Name="scaleTransform" />
                        <TranslateTransform x:Name="translateTransform" />
                    </TransformGroup>
                </Grid.RenderTransform>
                <StackPanel>
                    <Image
                        Width="400"
                        Height="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="pack://application:,,,/Resources/cat.jpeg"
                        Stretch="UniformToFill">
                        <Image.RenderTransform>
                            <MatrixTransform Matrix="1 0 0 1 0 0" />
                        </Image.RenderTransform>
                    </Image>
                    <Image
                        Width="400"
                        Height="300"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Source="pack://application:,,,/Resources/cat.jpeg"
                        Stretch="UniformToFill">
                        <Image.RenderTransform>
                            <MatrixTransform Matrix="2 0 0 2 0 0" />
                        </Image.RenderTransform>
                    </Image>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
