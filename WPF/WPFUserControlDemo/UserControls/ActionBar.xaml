<UserControl
    x:Class="WPFUserControlDemo.UserControls.ActionBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFUserControlDemo.UserControls"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="Uc"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:FieldModifier="private"
    mc:Ignorable="d">
    <Grid>
        <Border BorderThickness="2">
            <StackPanel>
                <DatePicker SelectedDate="{Binding ElementName=Uc, Path=BeginTime}" />
                <TextBox Text="{Binding ElementName=Uc, Path=Text}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
