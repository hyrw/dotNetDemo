<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WPFUserControlDemo"
    xmlns:uc="clr-namespace:WPFUserControlDemo.UserControls"
    xmlns:av="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="av"
    x:Class="WPFUserControlDemo.MainWindow"
    Title="MainWindow"
    Width="525"
    Height="350">
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>
    <StackPanel av:IsLocked="True">
        <uc:ActionBar BeginTime="{Binding BeginTime, Mode=TwoWay}" Text="{Binding Input, Mode=TwoWay}" av:IsLocked="True" />
        <TextBox Text="{Binding BeginTime}" av:IsLocked="True" />
        <TextBox Text="{Binding Input}" av:IsLocked="True" />
        <uc:ItemsEditor
            AddItem="{Binding AddItem}"
            Items="{Binding Items}"
            RemoveItem="{Binding RemoveItem}" av:IsLocked="True" />
    </StackPanel>
</Window>
