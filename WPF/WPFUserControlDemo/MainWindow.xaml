<Window
    x:Class="WPFUserControlDemo.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:WPFUserControlDemo"
    xmlns:uc="clr-namespace:WPFUserControlDemo.UserControls"
    Title="MainWindow"
    Width="525"
    Height="350">
    <Window.DataContext>
        <local:MainWindowViewModel />
    </Window.DataContext>
    <StackPanel>
        <uc:ActionBar BeginTime="{Binding BeginTime, Mode=TwoWay}" Text="{Binding Input, Mode=TwoWay}" />
        <TextBox Text="{Binding BeginTime}" />
        <TextBox Text="{Binding Input}" />
        <uc:ItemsEditor
            AddItem="{Binding AddItem}"
            Items="{Binding Items}"
            RemoveItem="{Binding RemoveItem}" />
    </StackPanel>
</Window>
