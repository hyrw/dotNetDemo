<Window x:Class="ControlDemoApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ControlDemoApp"
        xmlns:controls="clr-namespace:ControlLibrary.CustomControls;assembly=ControlLibrary"
        Background="#252525"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid VerticalAlignment="Center" Margin="100" >
        <Viewbox >
            <UniformGrid Columns="2" VerticalAlignment="Top">
                <controls:SmartDate Grid.Column="0" Margin="20" Width="216"/>
                <controls:AutoCompleteBox x:Name="autoComplete" ItemsSource="{Binding Names}" Grid.Column="2" Height="30" />
            </UniformGrid>
        </Viewbox>
    </Grid>
</Window>
