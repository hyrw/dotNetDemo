<Window
    x:Class="WpfViewModelLocator.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WpfViewModelLocator"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:view="clr-namespace:WpfViewModelLocator.View"
    Title="MainWindow"
    Width="800"
    Height="450"
    mc:Ignorable="d">
    <view:ViewA DataContext="{Binding Source={StaticResource ViewModelLocator}, Path=ViewAViewModel}" />
</Window>
