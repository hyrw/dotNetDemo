<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:B="clr-namespace:ControlLibrary.Behaviors"
    xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:controls="clr-namespace:ControlLibrary.Controls">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/SmartDate.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/CalendarSwitch.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/DayOfWeek.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/CalendarBox.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/CalendarBoxItem.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/ChevronButton.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/AutoCompleteBox.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/NumberRoll.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/FlipCard.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/FlipItem.xaml" />
        <ResourceDictionary Source="/ControlLibrary;component/Themes/Controls/ScaleAndTranslate.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="PageBtnStyle" TargetType="RadioButton">
        <Setter Property="Margin" Value="10" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <StackPanel Orientation="Horizontal">
                        <ContentPresenter
                            VerticalAlignment="Center"
                            RecognizesAccessKey="True"
                            SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" />
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:Pagination}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Pagination}">
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}">
                        <StackPanel Orientation="Horizontal">
                            <b:Interaction.Triggers>
                                <B:RoutedEventTrigger RoutedEvent="{x:Static RadioButton.CheckedEvent}">
                                    <b:InvokeCommandAction Command="NavigationCommands.GoToPage" />
                                </B:RoutedEventTrigger>
                            </b:Interaction.Triggers>
                            <Button Command="{x:Static NavigationCommands.FirstPage}" Content="First" />
                            <Button Command="{x:Static NavigationCommands.PreviousPage}" Content="Prev" />
                            <ItemsControl x:Name="PART_PagesContainer">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type controls:PaginationItem}">
                                        <RadioButton
                                            Command="{x:Static NavigationCommands.GoToPage}"
                                            CommandParameter="{Binding}"
                                            Content="{Binding Text}"
                                            GroupName="PageListGroup"
                                            Style="{StaticResource PageBtnStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <Button Command="{x:Static NavigationCommands.NextPage}" Content="Next" />
                            <Button Command="{x:Static NavigationCommands.LastPage}" Content="Last" />
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
</ResourceDictionary>
