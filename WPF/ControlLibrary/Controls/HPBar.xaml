<UserControl
    x:Class="ControlLibrary.Controls.HPBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:ControlLibrary.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    x:Name="root"
    d:DesignHeight="50"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid>
        <Rectangle
            x:Name="hpRect"
            Width="{Binding ElementName=root, Path=Width, Mode=OneWay}"
            HorizontalAlignment="Left"
            Fill="DarkRed" />
    </Grid>
</UserControl>
