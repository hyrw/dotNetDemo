<Button
    x:Class="WaterRipple.WaterRippleButton"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WaterRipple"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="300"
    d:DesignWidth="300"
    mc:Ignorable="d">
    <Button.Template>
        <ControlTemplate TargetType="Button">
            <Grid Background="{TemplateBinding Background}" ClipToBounds="True">
                <Border>
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalAlignment}" VerticalAlignment="{TemplateBinding VerticalAlignment}" />
                </Border>
                <Path x:Name="PART_Path" Fill="White">
                    <Path.Data>
                        <EllipseGeometry
                            x:Name="PART_Geometry"
                            RadiusX="0"
                            RadiusY="{Binding RelativeSource={RelativeSource Mode=Self}, Path=RadiusX}" />
                    </Path.Data>
                </Path>
            </Grid>
        </ControlTemplate>
    </Button.Template>
</Button>