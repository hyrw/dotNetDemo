<Button x:Class="WaterRipple.WaterRippleButton"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:WaterRipple"
        mc:Ignorable="d"
        d:DesignHeight="300" d:DesignWidth="300">
    <Button.Template>
        <ControlTemplate TargetType="Button">
            <Grid ClipToBounds="True" Background="{TemplateBinding Background}" MouseLeftButtonDown="UIElement_OnMouseLeftButtonDown">
                <Border>
                    <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalAlignment}"
                                      VerticalAlignment="{TemplateBinding VerticalAlignment}" />
                </Border>
                <Path Fill="White" x:Name="_path">
                    <Path.Data>
                        <EllipseGeometry x:Name="_geometry" RadiusX="0"
                                         RadiusY="{Binding RelativeSource={RelativeSource Mode=Self}, Path=RadiusX}" />
                    </Path.Data>
                </Path>
            </Grid>
        </ControlTemplate>
    </Button.Template>
</Button>