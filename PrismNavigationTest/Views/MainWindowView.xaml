<Window
    x:Class="PrismNavigationTest.Views.MainWindowView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:const="clr-namespace:PrismNavigationTest.Const"
    xmlns:prism="http://prismlibrary.com/"
    Title="{Binding Title}"
    Width="525"
    Height="350"
    prism:ViewModelLocator.AutoWireViewModel="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition />
            <RowDefinition />
            <RowDefinition Height="200" />
        </Grid.RowDefinitions>
        <StackPanel>
            <Button
                Click="ChangeWindow"
                Command="{Binding ClickCommand}"
                Content="Open Login Window" />
            <Button
                Command="{Binding ViewChangeCommand}"
                CommandParameter="A"
                Content="Sub View A" />
            <Button
                Command="{Binding ViewChangeCommand}"
                CommandParameter="B"
                Content="Sub View B" />
        </StackPanel>
        <TextBlock Grid.Row="1" Text="Main Window" />
        <ContentControl Grid.Row="2" prism:RegionManager.RegionName="{x:Static const:RegionNames.MainRegion}" />
    </Grid>
</Window>
